    "version": "0.2.0",
    "configurations": [
        {
            "name": "vehicle_parts_store (debug mode)",
            "request": "launch",
            "type": "dart",
            "flutterMode": "debug",
            "program": "lib/main.dart" // Ensure this points to your main entry file
        },
        {
            "name": "vehicle_parts_store (profile mode)",
            "request": "launch",
            "type": "dart",
            "flutterMode": "profile",
            "program": "lib/main.dart"
        },
        {
            "name": "vehicle_parts_store (release mode)",
            "request": "launch",
            "type": "dart",
            "flutterMode": "release",
            "program": "lib/main.dart"
        },
        {
            "name": "vehicle_parts_store (attach to device)",
            "request": "attach",
            "type": "dart",
            "deviceId": "flutter-tester" // Replace with your device ID or leave empty for auto-detection
        }
    ]
}